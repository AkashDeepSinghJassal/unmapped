name: Deploy → Azure Kubernetes Service

on:
  push:
    branches:
      - develop
  workflow_dispatch:

env:
  DOCKERHUB_USERNAME: ${{ secrets.DOCKERHUB_USERNAME }}
  IMAGE_TAG: ${{ github.sha }}
  AKS_RESOURCE_GROUP: ${{ secrets.AKS_RESOURCE_GROUP }}
  AKS_CLUSTER_NAME:   ${{ secrets.AKS_CLUSTER_NAME }}

jobs:
  # ── Job 1: build & push images to Docker Hub ─────────────────────────────────
  build-and-push:
    name: Build & Push to Docker Hub
    runs-on: ubuntu-latest

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Log in to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKERHUB_USERNAME }}
          password: ${{ secrets.DOCKERHUB_TOKEN }}

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      # ── Backend ────────────────────────────────────────────────────────────
      - name: Build & push backend
        uses: docker/build-push-action@v5
        with:
          context: .
          file: Dockerfile.backend
          push: true
          tags: |
            ${{ secrets.DOCKERHUB_USERNAME }}/unmapped-backend:${{ env.IMAGE_TAG }}
            ${{ secrets.DOCKERHUB_USERNAME }}/unmapped-backend:latest
          cache-from: type=registry,ref=${{ secrets.DOCKERHUB_USERNAME }}/unmapped-backend:latest
          cache-to: type=inline

      # ── Frontend ───────────────────────────────────────────────────────────
      - name: Build & push frontend
        uses: docker/build-push-action@v5
        with:
          context: .
          file: Dockerfile.frontend
          push: true
          build-args: |
            NEXT_PUBLIC_API_URL=https://${{ secrets.PUBLIC_DOMAIN }}/api
          tags: |
            ${{ secrets.DOCKERHUB_USERNAME }}/unmapped-frontend:${{ env.IMAGE_TAG }}
            ${{ secrets.DOCKERHUB_USERNAME }}/unmapped-frontend:latest
          cache-from: type=registry,ref=${{ secrets.DOCKERHUB_USERNAME }}/unmapped-frontend:latest
          cache-to: type=inline

  # ── Job 2: deploy to AKS ─────────────────────────────────────────────────────
  deploy:
    name: Deploy to AKS
    runs-on: ubuntu-latest
    needs: build-and-push
    environment: production

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Azure login
        uses: azure/login@v2
        with:
          creds: ${{ secrets.AZURE_CREDENTIALS }}

      - name: Get AKS credentials
        run: |
          az aks get-credentials \
            --resource-group $AKS_RESOURCE_GROUP \
            --name $AKS_CLUSTER_NAME \
            --overwrite-existing

      - name: Apply namespace, configmap, PVC
        run: |
          kubectl apply -f k8s/00-namespace.yaml
          kubectl apply -f k8s/01-configmap.yaml
          kubectl apply -f k8s/03-backend-pvc.yaml

      - name: Create / update Kubernetes secrets
        run: |
          kubectl create secret generic unmapped-secrets \
            --namespace unmapped \
            --from-literal=GROQ_API_KEY=${{ secrets.GROQ_API_KEY }} \
            --from-literal=OPENAI_API_KEY=${{ secrets.OPENAI_API_KEY || '' }} \
            --from-literal=GEMINI_API_KEY=${{ secrets.GEMINI_API_KEY || '' }} \
            --dry-run=client -o yaml | kubectl apply -f -

          # Docker Hub pull secret (needed if repo is private)
          kubectl create secret docker-registry dockerhub-secret \
            --namespace unmapped \
            --docker-server=https://index.docker.io/v1/ \
            --docker-username=${{ secrets.DOCKERHUB_USERNAME }} \
            --docker-password=${{ secrets.DOCKERHUB_TOKEN }} \
            --dry-run=client -o yaml | kubectl apply -f -

      - name: Deploy backend
        run: |
          sed -i "s|REGISTRY/unmapped-backend:latest|$DOCKERHUB_USERNAME/unmapped-backend:$IMAGE_TAG|g" \
            k8s/04-backend-deployment.yaml
          kubectl apply -f k8s/04-backend-deployment.yaml

      - name: Deploy frontend
        run: |
          sed -i "s|REGISTRY/unmapped-frontend:latest|$DOCKERHUB_USERNAME/unmapped-frontend:$IMAGE_TAG|g" \
            k8s/05-frontend-deployment.yaml
          kubectl apply -f k8s/05-frontend-deployment.yaml

      - name: Apply ingress
        run: kubectl apply -f k8s/06-ingress.yaml

      - name: Wait for rollouts
        run: |
          kubectl rollout status deployment/unmapped-backend  --namespace unmapped --timeout=180s
          kubectl rollout status deployment/unmapped-frontend --namespace unmapped --timeout=120s

      - name: Health check
        run: |
          sleep 10
          STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
            https://${{ secrets.PUBLIC_DOMAIN }}/api/health)
          if [ "$STATUS" != "200" ]; then
            echo "❌ Health check failed (HTTP $STATUS)"
            exit 1
          fi
          echo "✅ Live → https://${{ secrets.PUBLIC_DOMAIN }}" >> $GITHUB_STEP_SUMMARY
