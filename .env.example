# ── LLM (text generation) ────────────────────────────────────────────────────
# Provider: gemini (default) | openai | deepseek | groq | ollama
LLM_PROVIDER=groq
# Optional: override the default model for the chosen provider
# LLM_MODEL=llama-3.3-70b-versatile

# API keys — only the key for your chosen LLM_PROVIDER is required
# GEMINI_API_KEY=your_gemini_key       # https://aistudio.google.com/app/apikey
GROQ_API_KEY=your_groq_key_here        # https://console.groq.com  (FREE tier)
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...              # https://platform.deepseek.com
# OLLAMA_URL=http://localhost:11434    # local Ollama (no key needed)

# ── Embeddings ────────────────────────────────────────────────────────────────
# sentence_transformers = free/local (default, no key needed)
EMBEDDING_PROVIDER=sentence_transformers
ST_MODEL=all-MiniLM-L6-v2

# ── Storage ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=./data/unmapped.duckdb
CHROMA_PATH=./data/chroma
CONFIG_DIR=./config
